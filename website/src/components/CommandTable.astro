---
interface Props {
  commands: Array<{ command: string; description: string }>;
}

const { commands } = Astro.props;
---

<div class="table-wrap">
  <table class="command-table">
    <thead>
      <tr>
        <th>Command</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {commands.map((cmd) => (
        <tr>
          <td><code>{cmd.command}</code></td>
          <td>{cmd.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap {
    width: 100%;
    overflow-x: auto;
    margin-bottom: var(--space-6);
    border-radius: 8px;
    border: 1px solid var(--color-surface0);
  }

  .command-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .command-table thead tr {
    background: var(--color-surface0);
  }

  .command-table th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    color: var(--color-subtext1);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .command-table td {
    padding: var(--space-3) var(--space-4);
    color: var(--color-subtext1);
    border-top: 1px solid var(--color-surface0);
  }

  .command-table tbody tr:nth-child(even) {
    background: color-mix(in srgb, var(--color-surface0) 30%, transparent);
  }

  .command-table td code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-mauve);
    background: var(--color-bg-code);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    white-space: nowrap;
  }
</style>
