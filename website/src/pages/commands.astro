---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CommandTable from '../components/CommandTable.astro';
import KeyBindingTable from '../components/KeyBindingTable.astro';
import { Code } from 'astro:components';

const draftCommands = [
  { command: 'mp <file>', description: 'Preview a draft (dry-run)' },
  { command: 'mp new <name>', description: 'Create a new draft from template' },
  { command: 'mp list [dir]', description: 'List drafts grouped by status' },
  { command: 'mp validate <file|dir>', description: 'Validate frontmatter' },
  { command: 'mp mark-approved <file>', description: 'Mark draft as approved' },
  { command: 'mp mark-draft <file>', description: 'Demote approved draft back to draft' },
  { command: 'mp send <file> [-y]', description: 'Send a single approved email' },
  { command: 'mp send --invite ...', description: 'Send a calendar invitation (iMIP REQUEST)' },
  { command: 'mp send-approved [dir] [-y]', description: 'Send all approved emails' },
  { command: 'mp reply [file] [--all]', description: 'Create a reply draft' },
  { command: 'mp forward [file]', description: 'Create a forward draft' },
];

const imapCommands = [
  { command: 'mp fetch [filters]', description: 'Fetch emails from server' },
  { command: 'mp sync [options]', description: 'Sync local folders with server' },
  { command: 'mp watch [options]', description: 'Watch mailbox for changes (IMAP IDLE)' },
  { command: 'mp list-mailboxes', description: 'List available server mailboxes' },
  { command: 'mp archive <file>', description: 'Archive an email (server + local)' },
  { command: 'mp delete <file>', description: 'Delete an email (server + local)' },
  { command: 'mp search <query>', description: 'Search emails on server' },
  { command: 'mp open <file>', description: 'Open attachment in default app' },
  { command: 'mp save <file> [--output]', description: 'Save attachment(s) to directory' },
];

const configCommands = [
  { command: 'mp config init', description: 'Interactive setup wizard' },
  { command: 'mp config show', description: 'Display config (passwords masked)' },
  { command: 'mp config set-password', description: 'Store password in OS keyring' },
  { command: 'mp config oauth2-login', description: 'Run OAuth2 device code flow' },
  { command: 'mp config path', description: 'Print config file path' },
];

const fetchOptions = [
  { command: '--from <addr>', description: 'Filter by sender' },
  { command: '--to <addr>', description: 'Filter by recipient' },
  { command: '--cc <addr>', description: 'Filter by CC' },
  { command: '--subject <text>', description: 'Subject contains' },
  { command: '--body <text>', description: 'Body contains' },
  { command: '--since <YYYY-MM-DD>', description: 'Emails since date' },
  { command: '--before <YYYY-MM-DD>', description: 'Emails before date' },
  { command: '-n, --limit <N>', description: 'Max results (default: 10)' },
  { command: '--full', description: 'Show full body instead of preview' },
  { command: '--mailbox <name>', description: 'Mailbox name (default: INBOX)' },
];

const syncOptions = [
  { command: '-n, --limit <N>', description: 'Max messages per mailbox (default: 50)' },
  { command: '--mailbox <name>...', description: 'Mailboxes to sync (default: all configured)' },
  { command: '--reconcile', description: 'Also detect server-side moves and deletes' },
  { command: '--dry-run', description: 'Show what would change without modifying files' },
];

const globalOptions = [
  { command: '-s, --signature <name>', description: 'Use a specific signature' },
  { command: '--no-signature', description: 'Skip signature entirely' },
];

const inviteOptions = [
  { command: '--invite', description: 'Send an iMIP calendar invitation (METHOD:REQUEST)' },
  { command: '--to <addr>', description: 'Attendee(s), comma-separated (also the To header)' },
  { command: '--cc <addr>', description: 'CC attendee(s), comma-separated' },
  { command: '--subject <text>', description: 'Event summary (reused as the email subject)' },
  { command: '--start <when>', description: 'Start: local time or RFC3339 with offset' },
  { command: '--end <when>', description: 'End (same formats as --start); or use --duration' },
  { command: '--duration <dur>', description: 'Duration instead of --end: PT1H30M or 1h30m' },
  { command: '--location <text>', description: 'Optional event location' },
  { command: '--description <text>', description: 'Optional event description / body' },
];

const searchSyntax = [
  { command: 'from:', description: 'Filter by sender (IMAP FROM)' },
  { command: 'to:', description: 'Filter by recipient (IMAP TO)' },
  { command: 'cc:', description: 'Filter by CC (IMAP CC)' },
  { command: 'subject:', description: 'Filter by subject (IMAP SUBJECT)' },
  { command: 'body:', description: 'Filter by body content (IMAP BODY)' },
  { command: 'since:', description: 'Emails since date (YYYY-MM-DD)' },
  { command: 'before:', description: 'Emails before date (YYYY-MM-DD)' },
  { command: 'in:', description: 'Restrict search to a mailbox' },
  { command: 'bare text', description: 'Matches any field (IMAP TEXT)' },
];

const globalKeys = [
  { key: '1-9', action: 'Jump to mailbox by index' },
  { key: 'Tab / Shift-Tab', action: 'Cycle pane focus forward / backward' },
  { key: '/', action: 'Filter by metadata (subject, contact, date)' },
  { key: '\\', action: 'Search (includes body)' },
  { key: '!', action: 'Toggle activity log panel' },
  { key: 'L', action: 'Open activity log overlay' },
  { key: 'Ctrl+l', action: 'Open the current log file in $EDITOR' },
  { key: 'Ctrl+e', action: 'Open config.toml in $EDITOR (changes apply on restart)' },
  { key: '`', action: 'Switch account' },
  { key: 'Ctrl+1-9', action: 'Jump to account by index' },
  { key: '?', action: 'Help overlay' },
  { key: 'q', action: 'Quit' },
];

const listKeys = [
  { key: 'j / k', action: 'Navigate up / down' },
  { key: 'g g / G', action: 'Jump to top / bottom' },
  { key: 'Space', action: 'Toggle selection' },
  { key: 'Ctrl+a', action: 'Select all visible' },
  { key: 'Esc', action: 'Clear selection' },
  { key: 'Enter / e', action: 'Open in $EDITOR' },
  { key: 'r / R', action: 'Reply / Reply all' },
  { key: 'w', action: 'Forward' },
  { key: 'c', action: 'Edit recipients / subject (Drafts only)' },
  { key: 'a', action: 'Archive selected (with confirmation)' },
  { key: 'd', action: 'Delete selected (with confirmation)' },
  { key: 'm', action: 'Toggle read / unread' },
  { key: 'M', action: 'Move to mailbox (fuzzy picker)' },
  { key: 'A', action: 'Mark as approved' },
  { key: 'D', action: 'Mark approved as draft (reverse of A)' },
  { key: 'x', action: 'Send (with confirmation)' },
  { key: 'X', action: 'Send all approved (with confirmation)' },
  { key: 'n', action: 'New draft' },
  { key: 'y', action: 'Copy file path to clipboard' },
  { key: 's', action: 'Quick sync (fetch + reconcile, limit 100)' },
  { key: 'S', action: 'Full sync (fetch + reconcile, no limit)' },
  { key: 'f', action: 'Server search (IMAP)' },
  { key: 'o', action: 'Open attachment in default app' },
  { key: 'O', action: 'Save attachment(s) to directory' },
  { key: 'b', action: 'Open HTML version in browser' },
];
---

<Layout title="Commands -- mailypoppins" description="Complete reference for mailypoppins CLI commands and TUI key bindings.">
  <Nav />
  <main id="main-content" class="content page">
    <header class="page-header">
      <h1>Commands</h1>
      <p class="subtitle">Complete reference for CLI commands and TUI key bindings.</p>
    </header>

    <section>
      <h2 id="tui">TUI</h2>
      <p>
        Running <code>mp</code> with no arguments launches a full-screen terminal interface
        built on <code>ratatui</code>. The layout has four panes: a sidebar with the mailbox list,
        an email list, a headers pane, and a body preview. Panes adapt to terminal width -- the
        sidebar hides below 40 columns, and the right panes hide below 80 columns.
      </p>
      <p>
        The TUI calls library functions directly (no subprocess spawning). A background IMAP IDLE
        thread watches for new mail and triggers automatic fetches. For Graph API accounts, a
        timer-based poll checks every 60 seconds.
      </p>
    </section>

    <section>
      <h2 id="draft-commands">Draft Commands</h2>
      <CommandTable commands={draftCommands} />
    </section>

    <section>
      <h2 id="imap-commands">IMAP Commands</h2>
      <CommandTable commands={imapCommands} />
    </section>

    <section>
      <h2 id="config-commands">Config Commands</h2>
      <CommandTable commands={configCommands} />
    </section>

    <section>
      <h2 id="fetch-options">Fetch Options</h2>
      <CommandTable commands={fetchOptions} />
    </section>

    <section>
      <h2 id="sync-options">Sync Options</h2>
      <CommandTable commands={syncOptions} />
      <p>
        Sync is additive by default -- it fetches new emails only, deduplicated by Message-ID.
        A two-pass strategy first downloads headers (~50 bytes per message) to identify new emails,
        then fetches full RFC822 bodies only for messages not already stored locally.
      </p>
      <p>
        With <code>--reconcile</code>, a second pass detects server-side moves and deletes.
        It compares local files against INBOX and Archive on the server, moving or removing
        local files to match. The Sent directory is never reconciled -- locally-authored
        files are the source of truth.
      </p>
    </section>

    <section>
      <h2 id="invite-options">Invite Options (<code>mp send --invite</code>)</h2>
      <p>
        <code>mp send --invite</code> sends an iMIP calendar invitation
        (<code>METHOD:REQUEST</code>) over SMTP that renders as an actionable
        Accept / Tentative / Decline event in Outlook, Gmail, and Apple Mail.
        Attendees come from <code>--to</code>/<code>--cc</code> and the subject
        is reused as the event summary. Times accept local wall-clock
        (<code>2026-07-20T14:00</code>, <code>"2026-07-20 14:00"</code>) or
        RFC3339 with an offset (<code>2026-07-20T14:00:00+02:00</code>,
        <code>...Z</code>); provide either <code>--end</code> or
        <code>--duration</code>. The <code>ORGANIZER</code> is the sending
        account's primary address (Exchange drops mismatches). Graph accounts
        are not yet supported for invites.
      </p>
      <CommandTable commands={inviteOptions} />
    </section>

    <section>
      <h2 id="global-options">Global Options</h2>
      <CommandTable commands={globalOptions} />
    </section>

    <section>
      <h2 id="search-syntax">Search Query Syntax</h2>
      <p>
        The <code>mp search</code> command and the TUI server search overlay (<code>f</code>)
        accept structured queries with prefix operators. Quoted values are supported
        (e.g., <code>from:"John Doe"</code>). Without an <code>in:</code> prefix, all configured
        mailboxes are searched in sequence.
      </p>
      <CommandTable commands={searchSyntax} />
    </section>

    <section>
      <h2 id="tui-keys">TUI Key Bindings</h2>

      <h3 id="global-keys">Global</h3>
      <KeyBindingTable bindings={globalKeys} />

      <h3 id="list-keys">List Focus</h3>
      <KeyBindingTable bindings={listKeys} />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .page-header {
    margin-bottom: var(--space-12);
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--color-subtext0);
  }

  section {
    margin-bottom: var(--space-4);
  }
</style>
